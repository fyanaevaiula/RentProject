@model IEnumerable<MvcRentApp.Models.Bid>

@{
    ViewData["Title"] = "Заявки";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@*<h1>Index</h1>*@
<h2>Заявки</h2>
@*<p>
    <a asp-action="Create">Create New</a>
</p>*@
<p>
    @Html.ActionLink("Создать новую заявку", "Create")
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Phone)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Adress)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Number)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.bidDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Email)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Phone)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Adress)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Number)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.bidDate)
            </td>
            <td>
					@*<a asp-action="Edit" asp-route-id="@item.BidId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.BidId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.BidId">Delete</a>*@
                    @Html.ActionLink("Изменить", "Edit", new { id = item.BidId }) |
                    @Html.ActionLink("Подробнее", "Details", new { id = item.BidId }) |
                    @Html.ActionLink("Удалить", "Delete", new { id = item.BidId })
            </td>
        </tr>
}
    </tbody>
</table>
